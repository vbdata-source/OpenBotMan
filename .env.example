# ============================================
# OpenBotMan Environment Variables
# ============================================
# Kopiere diese Datei zu .env und passe die Werte an:
#   copy .env.example .env
#
# Die .env Datei wird NICHT ins Git committed (in .gitignore)
#
# WICHTIG: Nur API Keys hier! 
# Alle anderen Settings gehören in config.yaml
# ============================================

# ============================================
# API Server Authentication
# ============================================
# Komma-separierte Liste von API-Keys für den Server
# Diese Keys werden für die Authorization verwendet
OPENBOTMAN_API_KEYS=local-dev-key

# ============================================
# LLM Provider API Keys
# ============================================
# Anthropic (für claude-api Provider in config.yaml)
# Hol dir einen Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER

# Google Gemini (für google Provider in config.yaml)
# Hol dir einen Key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza_DEIN_KEY_HIER

# OpenAI (für openai Provider in config.yaml)
# Hol dir einen Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-DEIN_KEY_HIER

# ============================================
# Web Search (fuer das built-in web_search Tool)
# ============================================
# Brave Search API (empfohlen, kostenlos 2000 Queries/Monat)
# Hol dir einen Key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=BSA_DEIN_KEY_HIER

# Google Custom Search (alternativ zu Brave)
# Erstelle eine Custom Search Engine: https://programmablesearchengine.google.com/
# GOOGLE_CSE_ID=DEINE_CSE_ID_HIER
# (GOOGLE_API_KEY wird oben bereits gesetzt)

# Ohne Keys wird DuckDuckGo als Fallback genutzt (haeufig geblockt)

# ============================================
# KEINE SETTINGS HIER!
# ============================================
# Provider, Model, Agents, Timeouts etc.
# → alles in config.yaml konfigurieren!
